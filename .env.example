# ─────────────────────────────────────────────────────────────
# CardIndex environment variables
# Copy this file to .env.local and fill in your values.
# Add all of these to Vercel → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# 1. Create a project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the Project URL and anon/public key
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — used only in API routes (never exposed to browser)
# Found in Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Poketrace Pricing API ─────────────────────────────────────
# 1. Register at https://poketrace.com/dashboard
# 2. Copy your API key
POKETRACE_API_KEY=pc_live_xxxxxxxxxxxxxxxxxxxx

# ── Stripe (add when ready for payments) ─────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
